<AnchorPane prefHeight="665.0" prefWidth="600.0" style="-fx-background-radius: 10; -fx-background-color: white;" xmlns="http://javafx.com/javafx/18" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controls.AddNewUnitController">
